# Supabase — copy this file to .env.local and fill in your project values.
# Project URL + anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key is SECRET — server-side only, never prefixed with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
